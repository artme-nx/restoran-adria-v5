{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "ink": {
        "950": { "$value": "#071216", "$type": "color" },
        "900": { "$value": "#0D1B20", "$type": "color" },
        "800": { "$value": "#16282D", "$type": "color" },
        "700": { "$value": "#24393F", "$type": "color" }
      },
      "sand": {
        "100": { "$value": "#F6EEDF", "$type": "color" },
        "300": { "$value": "#D9C7A6", "$type": "color" },
        "500": { "$value": "#9C8D74", "$type": "color" }
      },
      "brass": {
        "300": { "$value": "#F0BE73", "$type": "color" },
        "500": { "$value": "#C98A34", "$type": "color" },
        "700": { "$value": "#8A5A1E", "$type": "color" },
        "900": { "$value": "#3E2A10", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-space-mono), 'Space Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "drift": { "$value": "2.2s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "tide": { "$value": "cubic-bezier(0.45, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.18em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "popover": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "primary": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.sand.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.brass.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "input": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "ring": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "radius": { "$value": "0.125rem", "$type": "dimension" },
    "gold": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "gold-light": { "$value": "{primitive.color.brass.300}", "$type": "color" },
    "gold-dim": { "$value": "{primitive.color.brass.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-tide": { "$value": "{primitive.motion.ease.tide}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "duration-drift": { "$value": "{primitive.motion.duration.drift}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.75rem, 8.5vw, 7rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.02", "$type": "number" },
      "kicker-size": { "$value": "0.72rem", "$type": "dimension" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 45% at 50% 100%, rgba(201, 138, 52, 0.24), rgba(62, 42, 16, 0.10) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to bottom, rgba(7, 18, 22, 0.55) 0%, rgba(7, 18, 22, 0.15) 32%, rgba(7, 18, 22, 0.35) 68%, #071216 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.brass.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.ink.950}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.brass.300}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.ink.950}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.ink.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.sand.500}", "$type": "color" }
    }
  }
}
